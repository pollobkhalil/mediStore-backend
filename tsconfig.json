{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "types": ["node"],
    "moduleResolution": "node",
    "ignoreDeprecations": "6.0",
    "outDir": "./dist",
    "rootDir": "./", // Change this to root to cover config files
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*",
    "prisma.config.ts", // Explicitly include the config file
    ".env" 
  ],
  "exclude": [
    "node_modules",
    "dist",
    "generated/prisma"
  ]
}